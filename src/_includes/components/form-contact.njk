<link rel="stylesheet" href="/contact.css">

{% set translate = site.componentTranslations.contact %}

<section class="contact no-print">
  <h2>{{translate.title[lang]}}</h2>

  <div class="contact-card">
    <p class="contact-intro">
      {{translate.intro[lang]}}
    </p>

    <form
      class="contact-form"
      action="https://formspree.io/f/xgolgevd"
      method="POST"
      novalidate
      data-err-name="{{translate.errors.name[lang]}}"
      data-err-email-empty="{{translate.errors.emailEmpty[lang]}}"
      data-err-email-invalid="{{translate.errors.emailInvalid[lang]}}"
      data-err-message="{{translate.errors.message[lang]}}"
      data-sent="{{translate.sent[lang]}}"
      data-status-success="{{translate.statusSuccess[lang]}}"
      data-status-error="{{translate.statusError[lang]}}"
    >
      <!-- Honeypot -->
      <input type="text" name="_gotcha" class="hidden-field" tabindex="-1" autocomplete="off" aria-hidden="true">

      <div class="field">
        <label for="name">{{translate.name[lang]}}</label>
        <input id="name" type="text" name="name" required aria-required="true" />
      </div>

      <div class="field">
        <label for="email">{{translate.mail[lang]}}</label>
        <input id="email" type="email" name="email" required aria-required="true" />
      </div>

      <div class="field">
        <label for="message">{{translate.message[lang]}}</label>
        <textarea id="message" name="message" rows="4" required aria-required="true"></textarea>
      </div>

      <button type="submit">
        <span class="btn-text">{{translate.button[lang]}}</span>
      </button>

      <p class="form-status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script src="/contact.js"></script>
