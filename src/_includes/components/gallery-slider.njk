{% macro data(gallery) %}
  <h1>{{[gallery.type, "-item"] | join}}</h1>
  <section class="gallery-section">
    <div class={{[gallery.type, "-grid"] | join}}>
      {% for item in gallery.items %}
        <div class={{[gallery.type, "-item"] | join}}>
          {% if item.type == "webm" %}
            {% if item.href %}
              <a href="{{ item.href }}" class="gallery-link" target="_blank" rel="noopener">
                <video preload="metadata" {% for attr in item.attrs %} {{attr}} {% endfor %}>
                  <source src="{{ item.src }}" type="video/webm">
                </video>
              </a>
            {% else %}
              <video preload="metadata" {% for attr in item.attrs %} {{attr}} {% endfor %}>
                <source src="{{ item.src }}" type="video/webm">
              </video>
            {% endif %}
          {% elif item.type == "embed" %}
            <div class={{[gallery.type, "-embed"] | join}}>
              {{ item.embed | safe }}
            </div>
          {% else %}
            {% if item.href %}
              <a href="{{ item.href }}" class="gallery-link" target="_blank" rel="noopener">
                <img src="{{ item.src }}" alt="{{ item.alt or '' }}" loading="lazy">
              </a>
            {% else %}
              <img src="{{ item.src }}" alt="{{ item.alt or '' }}" loading="lazy">
            {% endif %}
          {% endif %}

        </div>
      {% endfor %}
    </div>
  </section>
{% endmacro %}