{% set t = translations[lang] %}

<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>

  {% for l in site.languages %}
    <link rel="alternate" hreflang="{{ l }}" href="/{{ l }}/" />
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="/{{ site.defaultLang }}/" />

  <link rel="stylesheet" href="/style.css">
  <script>var t=localStorage.getItem('theme');if(t)document.documentElement.setAttribute('data-theme',t);</script>
</head>
<body>
  {% include "components/header.njk" %}
  
  <div class="template-content">
    {{ content | safe }}
  </div>
  
  <div class="no-print">
    {% include "components/footer.njk" %}
  </div>
</body>
<script src="/app.js"></script>
</html>